# MacOS Agent Platform - Environment Configuration
# Copy this to .env and fill in your values

# Server settings
HOST=127.0.0.1
PORT=8000
DEBUG=false
OPEN_BROWSER_ON_START=true

# Ollama settings (local model server)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=gemma3:4b

# Optional cloud providers (leave blank to use local only)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model routing strategy: local_first | cloud_first | local_only
MODEL_ROUTING=local_first

# Safety settings
REQUIRE_CONFIRMATION_FOR_ACTIONS=true
DRY_RUN_MODE=false
SAFE_MODE=false

# Storage
DB_PATH=./data/agent.db
LOG_PATH=./data/logs

# Security
SECRET_KEY=change-me-to-a-random-string-in-production
